# RaportRBR v1.0 — konfiguracja środowiska
# Skopiuj jako .env i uzupełnij wartości

# Baza danych PostgreSQL (Railway uzupełnia automatycznie)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Sekretny klucz JWT — wpisz długi losowy ciąg
JWT_SECRET=raportrbr-zmien-ten-klucz-2024

# Środowisko
NODE_ENV=production

# Port (Railway ustawia automatycznie)
PORT=3001

# SMTP — wysyłanie raportów email
# Dla Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=twoj@gmail.com
SMTP_PASS=haslo-aplikacji-gmail
