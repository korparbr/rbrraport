PORT=3001
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Wymagane. W produkcji musi miec minimum 32 znaki, najlepiej 64+.
# Wygeneruj wlasny sekret i NIE udostepniaj go publicznie.
JWT_SECRET=tu_wpisz_bardzo_dlugi_losowy_sekret_minimum_32_znaki

# Uzywane tylko wtedy, gdy konto ADMIN jeszcze nie istnieje.
# Po pierwszym logowaniu system wymusi zmiane hasla.
ADMIN_INITIAL_PASSWORD=admin123!@#

LOGIN_LOCK_MAX=5
LOGIN_LOCK_MINUTES=15

# Opcjonalne, jesli uzywasz wysylki maili.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
