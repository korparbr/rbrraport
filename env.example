PORT=3001
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Wymagane. W produkcji musi miec minimum 32 znaki, najlepiej 64+.
# Wygeneruj wlasny sekret i NIE udostepniaj go publicznie.
JWT_SECRET=tu_wpisz_bardzo_dlugi_losowy_sekret_minimum_32_znaki

# Adresy, z ktorych aplikacja moze laczyc sie z API.
# Po uruchomieniu na domenie dopisz np. https://twoja-domena.pl
# "null" zostaw tylko jesli nadal otwierasz index.html jako plik file:// z dysku.
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,http://127.0.0.1:3001,http://127.0.0.1:3000,null

# true pozwala laczyc sie z prywatnej sieci LAN, np. http://192.168.1.50:3001 z telefonu.
# Na publicznej produkcji z domena mozesz ustawic false i wpisac dokladna domene w ALLOWED_ORIGINS.
ALLOW_PRIVATE_NETWORK_ORIGINS=true

# Uzywane tylko wtedy, gdy konto ADMIN jeszcze nie istnieje.
# Po pierwszym logowaniu system wymusi zmiane hasla.
ADMIN_INITIAL_PASSWORD=admin123!@#

LOGIN_LOCK_MAX=5
LOGIN_LOCK_MINUTES=15

# Opcjonalne, jesli uzywasz wysylki maili.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
